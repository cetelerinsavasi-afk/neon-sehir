# Firebase konsolu > Project settings > General > Your apps kısmından kopyala.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Cloud Functions'ı deploy ederken kullandığın bölge ile BİREBİR aynı olmalı
# (functions/index.js içindeki setGlobalOptions({ region: ... }) ile eşleşmeli).
VITE_FIREBASE_FUNCTIONS_REGION=europe-west1
