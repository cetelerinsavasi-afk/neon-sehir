rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ---------------------------------------------------------------------
    // users/{uid} — oyuncu profili.
    // Tüm kritik alanlar (gold, suspicion, profession vb.) sadece Cloud
    // Functions (Admin SDK) tarafından yazılabilir; Admin SDK bu kuralları
    // zaten bypass eder. İstemcinin doğrudan yazması burada tamamen
    // engellenmiştir (Bölüm 15).
    // ---------------------------------------------------------------------
    match /users/{uid} {
      allow read: if isSelf(uid);
      allow write: if false;

      // isPolice — Bölüm 14 gereği sadece doküman sahibi okuyabilir.
      // Cloud Functions (soygun/heist mantığı, Faz 5) Admin SDK ile
      // bu kısıtlamayı bypass ederek okuyabilir.
      match /private/{docId} {
        allow read: if isSelf(uid);
        allow write: if false;
      }

      match /productionMachines/{machineId} {
        allow read: if isSelf(uid);
        allow write: if false;
      }

      match /inventory/{itemId} {
        allow read: if isSelf(uid);
        allow write: if false;
      }

      // messages/{msgId} — SMS gelen kutusu (soygun sızma uyarısı vb.).
      match /messages/{msgId} {
        allow read: if isSelf(uid);
        allow write: if false;
      }
    }

    // ---------------------------------------------------------------------
    // dailyActions/{uid}_{YYYY-MM-DD} — günlük hak takibi.
    // Sadece kendi dokümanını okuyabilir; ID formatı "{uid}_..." olduğu
    // için split ile kontrol ediyoruz.
    // ---------------------------------------------------------------------
    match /dailyActions/{docId} {
      allow read: if isSignedIn() && docId.split('_')[0] == request.auth.uid;
      allow write: if false;
    }

    // ---------------------------------------------------------------------
    // Herkese açık, salt-okunur veriler (Cloud Functions tarafından yazılır)
    // ---------------------------------------------------------------------
    match /investments/{date} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // investmentHistory/{docId} — saatlik fiyat geçmişi (çizgi grafik için).
    match /investmentHistory/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // onNumaraTables/{tableId} — "10 Numara" kart oyunu masaları.
    match /onNumaraTables/{tableId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // mosqueAttendance/{dateKey}/members/{uid} — "Bugünkü Cemaat" listesi.
    match /mosqueAttendance/{dateKey}/members/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // beggars/{dateKey}/entries/{uid} — günlük dilenci listesi.
    match /beggars/{dateKey}/entries/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // imamState/current — oyundaki tek imamın bilgisi (herkes görebilir).
    // imamState/meta — son azledilen imam uid'si (sadece Cloud Functions okur/yazar).
    match /imamState/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // factories/{ownerId} — oyuncu fabrikaları. Herkes görebilir (fabrika
    // listesi/rekabet için), yazma sadece Cloud Functions ile.
    match /factories/{ownerId} {
      allow read: if isSignedIn();
      allow write: if false;

      match /machines/{machineId} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }

    match /shipSchedule/{date} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // limanOrders/{uid} — oyuncunun mevcut turdaki bekleyen Liman siparişi.
    // Sadece kendi siparişini görebilir; yazma sadece Cloud Functions ile.
    match /limanOrders/{orderUid} {
      allow read: if isSignedIn() && orderUid == request.auth.uid;
      allow write: if false;
    }

    // heistPlans/{planId} — ekip soygun planları. Herkes görüp katılabilmeli,
    // bu yüzden herkese açık okunur; yazma sadece Cloud Functions ile.
    match /heistPlans/{planId} {
      allow read: if isSignedIn();
      allow write: if false;

      match /participants/{participantUid} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }

    // raceRooms/{roomId} — yarış pisti odaları. Herkes açık odaları görüp
    // katılabilmeli; yazma sadece Cloud Functions ile.
    match /raceRooms/{roomId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // trainingProgress/{uid} — antrenman modunda açılan seviyeler/ödül
    // alınan seviyeler. Sadece sahibi okuyabilir.
    match /trainingProgress/{uid} {
      allow read: if isSelf(uid);
      allow write: if false;
    }

    // lottery/{dateKey} — piyango. Herkes güncel jackpot'u ve geçmiş
    // kazananları görebilmeli; yazma sadece Cloud Functions ile.
    match /lottery/{dateKey} {
      allow read: if isSignedIn();
      allow write: if false;

      match /tickets/{ticketUid} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }

    // marketplaceListings/{listingId} — 2. el satış ilanları (Bölüm 9.1).
    // Herkes ilanları görüp satın alabilmeli; yazma sadece Cloud Functions.
    match /marketplaceListings/{listingId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // globalChat/{msgId} — ChatsApp, tüm oyunculara açık genel sohbet.
    match /globalChat/{msgId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // usernames/{lowercaseName} — benzersiz oyun içi isim rezervasyonu.
    // Sadece varlık kontrolü için okunabilir; yazma Cloud Functions ile.
    match /usernames/{name} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /weapons/{weaponId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /vehicles/{vehicleId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Tanımlanmamış her şey varsayılan olarak kapalı.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
